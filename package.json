{
	"name": "celestia-org-nextjs-site",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --webpack",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"verify": "npm run lint && npm run typecheck && npm run build",
		"test": "node --test \"src/**/*.test.mjs\"",

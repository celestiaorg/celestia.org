		"check-links": "bash scripts/check-links.sh",
		"prepare": "husky"
	},
	"dependencies": {
		"@tailwindcss/line-clamp": "^0.4.4",
		"bowser": "^2.13.1",
		"clsx": "^2.1.1",
		"framer-motion": "^11.2.13",
		"gray-matter": "^4.0.3",
		"lumina-node": "^0.10.0",
		"markdown-to-jsx": "^7.4.7",
		"next": "^16.2.10",
		"next-plausible": "^3.12.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-slick": "^0.31.0",
		"react-stickynode": "^4.1.1",
		"sass": "^1.77.8",
		"slick-carousel": "^1.8.1",
		"tailwind-merge": "^3.3.0",
		"tailwind-variants": "^3.2.2"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"copy-webpack-plugin": "^14.0.0",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.10",
		"husky": "^9.1.7",
		"linkinator": "^6.1.2",
		"postcss": "^8.5.16",
		"tailwindcss": "^3.4.1",
		"typescript": "^6.0.3"
	},
